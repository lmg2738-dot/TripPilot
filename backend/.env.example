# Database (로컬 개발)
DATABASE_URL=sqlite+aiosqlite:///./trippilot.db

# OpenRouter (무료 모델 자동 선택)
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=https://trippilot.ai
OPENROUTER_APP_NAME=TripPilot AI

# 공공데이터포털 (기상청·관광공사·열차 공통)
PUBLIC_DATA_API_KEY=

# 도로공사
EX_API_KEY=

# KIPRIS / KOSIS (향후 확장)
KIPRIS_API_KEY=
KOSIS_API_KEY=

# Supabase (Vercel 프로덕션 DB)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# App
CORS_ORIGINS=http://localhost:3000
FREE_TRIP_LIMIT=10
