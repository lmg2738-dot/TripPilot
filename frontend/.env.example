# Vercel (프론트엔드 + API Routes)

# Supabase (클라이언트 노출 가능)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenRouter (서버 전용 - Vercel Environment Variables)
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=https://trippilot.vercel.app
OPENROUTER_APP_NAME=TripPilot AI

# 공공데이터포털 (서버 전용)
PUBLIC_DATA_API_KEY=

# 도로공사 (서버 전용)
EX_API_KEY=

# KIPRIS / KOSIS (서버 전용, 향후 확장)
KIPRIS_API_KEY=
KOSIS_API_KEY=

# App
FREE_TRIP_LIMIT=3
